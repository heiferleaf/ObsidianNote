# Obsidian 系统文件夹
.obsidian/
.trash/

# macOS 系统文件
.DS_Store

# Node.js（如果使用的话）
node_modules/

# 编辑器临时文件
*.swp
*.swo
*~


# 环境变量文件
.env
.env.local

# 排除所有文件夹（除了你想要的）
/*
!.gitignore
!.git/
!index.md

# 只保留这些文件夹
!/002-学习笔记/
!/003-Attachments/
!/quartz/
!/.github/

# quartz 生成的临时文件
quartz/node_modules/
quartz/public/
quartz/.next/
quartz/dist/
quartz/*.cache
!/.github/workflows/
!/.github/workflows/*.yml
!/.github/workflows/*.yaml